{
	"compilerOptions": {
		"lib": ["esnext"],
		"target": "esnext",
		"module": "nodenext",
		"moduleDetection": "force",
		"moduleResolution": "nodenext",
		"sourceMap": true,
		"esModuleInterop": true,
		"noImplicitAny": true,
		"noImplicitOverride": true,
		"noImplicitReturns": true,
		"noImplicitThis": true,
		"resolveJsonModule": true,
		"skipDefaultLibCheck": true,
		"skipLibCheck": true,
		"types": ["node"]
	}
}
