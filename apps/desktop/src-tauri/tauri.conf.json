{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "Proponente Digital",
	"version": "0.1.0",
	"identifier": "br.com.proponentedigital.desktop",
	"build": {
		"beforeDevCommand": "pnpm dev",
		"devUrl": "http://localhost:1420",
		"beforeBuildCommand": "pnpm build",
		"frontendDist": "../dist",
		"removeUnusedCommands": true
	},
	"app": {
		"withGlobalTauri": false,
		"windows": [
			{
				"label": "main",
				"title": "Proponente Digital",
				"width": 1280,
				"height": 720,
				"minWidth": 960,
				"minHeight": 640,
				"resizable": true,
				"maximizable": true,
				"minimizable": true,
				"closable": true,
				"center": true,
				"visible": false,
				"decorations": true,
				"devtools": false,
				"dragDropEnabled": true
			}
		],
		"security": {
			"csp": "default-src 'self'; connect-src 'self' http://localhost:3000 https://api.proponentedigital.com.br; img-src 'self' data: blob: asset: http://asset.localhost; style-src 'self' 'unsafe-inline'; script-src 'self'; font-src 'self' data:"
		}
	},
	"bundle": {
		"active": true,
		"createUpdaterArtifacts": true,
		"targets": ["nsis"],
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		],
		"windows": {
			"allowDowngrades": false,
			"webviewInstallMode": {
				"silent": true,
				"type": "downloadBootstrapper"
			},
			"nsis": {
				"installMode": "currentUser",
				"displayLanguageSelector": false,
				"installerIcon": "icons/icon.ico",
				"uninstallerIcon": "icons/icon.ico"
			}
		}
	},
	"plugins": {
		"deep-link": {
			"desktop": {
				"schemes": ["proponente"]
			}
		},
		"updater": {
			"pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDVGODVGQ0MzMTFCMUQ1QTEKUldTaDFiRVJ3L3lGWDFXVkJjYU95OVJmd0x5OGZJbW4rSmNpbXppWUZWTVlRZXZlaUtGanF2ZWYK",
			"endpoints": [
				"https://github.com/freitaseric/proponente-platform/releases/latest/download/latest.json"
			]
		}
	}
}
