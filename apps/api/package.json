{
	"name": "captaflow-api",
	"main": "dist/app.js",
	"scripts": {
		"dev": "tsx watch src/app.ts",
		"build": "tsc -p tsconfig.build.json",
		"typecheck": "tsc -p tsconfig.json --noEmit",
		"check": "pnpm run typecheck && pnpm run lint",
		"format": "biome format",
		"lint": "biome lint"
	},
	"license": "Apache-2.0",
	"packageManager": "pnpm@11.9.0",
	"engines": {
		"node": ">=22"
	},
	"type": "module",
	"devDependencies": {
		"@captaflow/config": "workspace:*",
		"@captaflow/contracts": "workspace:*",
		"@biomejs/biome": "2.5.1",
		"@types/node": "26.0.1",
		"@types/pg": "8.20.0",
		"@types/semver": "7.7.1",
		"drizzle-kit": "1.0.0-rc.4",
		"tsx": "4.22.4",
		"typescript": "6.0.3"
	},
	"dependencies": {
		"@better-auth/drizzle-adapter": "1.6.22",
		"@fastify/cors": "11.2.0",
		"@fastify/static": "9.1.3",
		"@fastify/swagger": "9.7.0",
		"@fastify/swagger-ui": "6.0.0",
		"better-auth": "1.6.22",
		"dotenv": "17.4.2",
		"drizzle-orm": "1.0.0-rc.4",
		"fastify": "5.8.5",
		"fastify-type-provider-zod": "7.0.0",
		"pg": "8.22.0",
		"pino-pretty": "13.1.3",
		"semver": "7.8.5",
		"zod": "4.4.3"
	}
}
