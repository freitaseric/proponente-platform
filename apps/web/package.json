{
	"name": "proponente-web",
	"private": true,
	"version": "0.1.0",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "tsc && vite build",
		"typecheck": "tsc -b --pretty false",
		"check": "pnpm run typecheck && pnpm run lint",
		"lint": "biome lint",
		"format": "biome format",
		"preview": "vite preview"
	},
	"packageManager": "pnpm@11.9.0",
	"engines": {
		"node": ">=22"
	},
	"imports": {
		"#components/*": "./src/components/*.tsx",
		"#lib/*": "./src/lib/*.ts",
		"#hooks/*": "./src/hook/*.ts"
	},
	"dependencies": {
		"@fontsource-variable/inter": "^5.2.8",
		"@proponente/ui": "workspace:*",
		"@tailwindcss/vite": "4.3.1",
		"@tanstack/react-router": "1.170.16",
		"@tanstack/router-plugin": "^1.168.18",
		"better-auth": "1.6.22",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"lucide-react": "1.22.0",
		"next-themes": "^0.4.6",
		"radix-ui": "^1.6.0",
		"react": "19.2.7",
		"react-dom": "19.2.7",
		"shadcn": "^4.12.0",
		"sonner": "^2.0.7",
		"tailwind-merge": "^3.6.0",
		"tailwindcss": "4.3.1",
		"tw-animate-css": "^1.4.0",
		"zod": "4.4.3"
	},
	"devDependencies": {
		"@biomejs/biome": "2.5.1",
		"@proponente/config": "workspace:*",
		"@tanstack/react-router-devtools": "^1.167.0",
		"@types/react": "19.2.17",
		"@types/react-dom": "19.2.3",
		"@vitejs/plugin-react": "6.0.3",
		"typescript": "6.0.3",
		"vite": "8.1.0"
	}
}
